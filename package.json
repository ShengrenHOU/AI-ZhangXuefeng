{
  "name": "gaokao-mvp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "api:dev": ".\\.venv\\Scripts\\uvicorn gaokao_api.main:app --app-dir services/api/src --host 0.0.0.0 --port 8000 --reload",
    "api:test": ".\\.venv\\Scripts\\python -m pytest services/api/tests",
    "install:web": "pnpm install --filter @gaokao-mvp/web...",
    "dev:web": "pnpm --filter @gaokao-mvp/web dev",
    "build:web": "pnpm --filter @gaokao-mvp/web build",
    "check:web": "pnpm --filter @gaokao-mvp/web typecheck && pnpm --filter @gaokao-mvp/web build"
  }
}
